{
  "name": "atocha",
  "version": "3.0.0",
  "description": "Tiny exec() with Promises and trim()",
  "homepage": "https://github.com/franciscop/atocha#readme",
  "repository": "https://github.com/franciscop/atocha.git",
  "bugs": "https://github.com/franciscop/atocha/issues",
  "funding": "https://www.paypal.me/franciscopresencia/19",
  "author": "Francisco Presencia <public@francisco.io> (https://francisco.io/)",
  "license": "MIT",
  "scripts": {
    "build": "npm run build:bundle && npm run build:types",
    "build:bundle": "bun build src/index.ts --outfile=index.min.js --minify --format=esm --target=node",
    "build:types": "dts-bundle-generator --out-file index.d.ts --project tsconfig.json src/index.ts",
    "lint": "tsc",
    "size": "echo $(gzip -c index.min.js | wc -c) bytes",
    "start": "bun test --watch",
    "test": "bun test"
  },
  "keywords": [
    "exec",
    "console",
    "terminal",
    "promise",
    "promises",
    "async",
    "await",
    "cli"
  ],
  "main": "index.min.js",
  "files": [
    "index.min.js",
    "index.d.ts"
  ],
  "types": "index.d.ts",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "swear": "^2.0.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "dts-bundle-generator": "^9.5.1",
    "typescript": "^5.7.3"
  }
}
